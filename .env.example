# NEVER commit the actual .env file to GitHub.

# ── Gemini AI (used by FastAPI backend engines) ──
GEMINI_API_KEY=your-gemini-api-key-here

# ── Google Calendar OAuth (used by CalendarSense) ──
# Place credentials.json and token.json in the project root.
# These are git-ignored for security.
